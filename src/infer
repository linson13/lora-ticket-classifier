"""
Quick single-input demo: run the fine-tuned model on one message you type in.

Usage:
    python src/infer.py --adapter_dir outputs/lora-adapter --text "My app crashed and I want a refund"
"""

import argparse

import torch
from peft import PeftModel
from transformers import AutoModelForCausalLM, AutoTokenizer

from train import SYSTEM_PROMPT


def main():
    parser = argparse.ArgumentParser(description="Run the fine-tuned model on a single input.")
    parser.add_argument("--model_name", type=str, default="Qwen/Qwen2.5-0.5B-Instruct")
    parser.add_argument("--adapter_dir", type=str, default="outputs/lora-adapter")
    parser.add_argument("--text", type=str, required=True, help="Support message to classify")
    args = parser.parse_args()

    tokenizer = AutoTokenizer.from_pretrained(args.model_name)
    if tokenizer.pad_token is None:
        tokenizer.pad_token = tokenizer.eos_token

    base_model = AutoModelForCausalLM.from_pretrained(args.model_name, device_map="auto")
    model = PeftModel.from_pretrained(base_model, args.adapter_dir)

    messages = [
        {"role": "system", "content": SYSTEM_PROMPT},
        {"role": "user", "content": args.text},
    ]
    prompt = tokenizer.apply_chat_template(messages, tokenize=False, add_generation_prompt=True)
    inputs = tokenizer(prompt, return_tensors="pt").to(model.device)

    with torch.no_grad():
        output = model.generate(
            **inputs,
            max_new_tokens=60,
            do_sample=False,
            pad_token_id=tokenizer.pad_token_id,
        )

    generated = output[0][inputs["input_ids"].shape[1]:]
    result = tokenizer.decode(generated, skip_special_tokens=True)

    print(f"\nInput:  {args.text}")
    print(f"Output: {result.strip()}")


if __name__ == "__main__":
    main()
